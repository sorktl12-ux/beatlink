# Supabase: Dashboard > Project Settings > API
# Copy the Project URL and the anon/public key, then save this file as .env
#
# Also do this once in the Supabase dashboard:
#   1) SQL Editor > run the contents of supabase/schema.sql
#   2) Authentication > Providers > Email: turn OFF "Confirm email"
#      (this app uses synthetic <id>@beatlink.app emails, so confirmation must be disabled)
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
