# Supabase: Dashboard → Project Settings → API
# Copy URL + anon key into .env (never commit .env)
#
# One-time Supabase setup:
#   1) SQL Editor → run supabase/schema.sql
#   2) Authentication → Providers → Email → turn OFF "Confirm email"
#   3) Admin: create auth user for your admin ID, then in SQL Editor:
#        update public.profiles
#        set role = 'admin', seller_approved = true
#        where username = 'sorktl12';
#
# Deploy is local-only: npm run deploy (requires ~/.ssh/id_ed25519_beatlink + Vercel CLI login)
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
