# Local admin setup only — copy to .env.admin (gitignored). Never commit.
# Get service_role: Supabase Dashboard → Settings → API → service_role
# Get DB URL: Connect → Direct → Session pooler → URI
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
